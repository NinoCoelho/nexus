        "id": "local_claude_code",
        "label": "Use Claude Code sign-in",
        "priority": 30,
        "prompts": []
      },
      {
        "id": "oauth_device",
        "label": "Sign in with Claude Pro / Max",
        "priority": 50,
        "oauth": {
          "flavor": "device",
          "client_id": "",
          "auth_url": "https://claude.ai/oauth/authorize",
          "token_url": "https://claude.ai/oauth/token",
          "device_url": "https://claude.ai/oauth/device/code",
          "scopes": ["org:create_api_key", "user:profile", "user:inference"],
          "pkce": true
        }
      },
      {
        "id": "api",
        "label": "API key",
        "priority": 100,
        "prompts": [
          {
            "name": "ANTHROPIC_API_KEY",
            "label": "API key",
            "kind": "password",
            "placeholder": "sk-ant-...",
            "help": "Get a key at console.anthropic.com/settings/keys.",
            "help_url": "https://console.anthropic.com/settings/keys",
            "secret": true,
            "required": true
          }
        ]
      }
    ],
    "default_models": [
      {"id": "claude-opus-4-7", "capabilities": ["chat", "tools", "vision", "reasoning", "document"]},
      {"id": "claude-sonnet-4-6", "capabilities": ["chat", "tools", "vision", "document"]},
      {"id": "claude-haiku-4-5-20251001", "capabilities": ["chat", "tools", "vision", "document"]}
    ],
    "docs_url": "https://docs.anthropic.com"
