  {
    "id": "bedrock",
    "display_name": "AWS Bedrock",
    "category": "cloud",
    "runtime_kind": "bedrock",
    "base_url_template": "https://bedrock-runtime.{region}.amazonaws.com",
    "env_var_names": ["AWS_PROFILE", "AWS_BEARER_TOKEN_BEDROCK"],
    "auth_methods": [
      {
        "id": "iam_aws",
        "label": "AWS profile / IAM",
        "priority": 100,
        "requires_extra": "bedrock",
        "prompts": [
          {
            "name": "iam_profile",
            "label": "AWS profile",
            "kind": "text",
            "placeholder": "default",
            "help": "Named profile from ~/.aws/credentials. Leave empty to use the default credential chain.",
            "required": false
          },
          {
            "name": "iam_region",
            "label": "Region",
            "kind": "select",
            "choices": [
              "us-east-1",
              "us-east-2",
              "us-west-2",
              "eu-west-1",
              "eu-central-1",
              "ap-northeast-1",
              "ap-south-1"
            ],
            "default": "us-east-1",
            "required": true
          }
        ]
      }
    ],
    "default_models": [
      "anthropic.claude-opus-4-1-20250805-v1:0",
      "anthropic.claude-sonnet-4-5-20250929-v1:0",
      "anthropic.claude-3-5-haiku-20241022-v1:0"
    ],
    "docs_url": "https://docs.aws.amazon.com/bedrock"
  },
  {
    "id": "vertex-ai",
