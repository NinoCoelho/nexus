[
  {
    "id": "openai",
    "display_name": "OpenAI",
    "category": "frontier",
    "runtime_kind": "openai_compat",
    "base_url": "https://api.openai.com/v1",
    "env_var_names": ["OPENAI_API_KEY"],
    "auth_methods": [
      {
        "id": "local_codex",
        "label": "Use Codex sign-in",
        "priority": 30,
        "prompts": []
      },
      {
        "id": "api",
        "label": "API key",
        "priority": 100,
        "prompts": [
          {
            "name": "OPENAI_API_KEY",
            "label": "API key",
            "kind": "password",
            "placeholder": "sk-...",
            "help": "Get a key at platform.openai.com/api-keys.",
            "help_url": "https://platform.openai.com/api-keys",
            "secret": true,
            "required": true
          }
        ]
      }
    ],
    "default_models": [
      {"id": "gpt-4o", "capabilities": ["chat", "tools", "vision"]},
      {"id": "gpt-4o-mini", "capabilities": ["chat", "tools", "vision"]},
      {"id": "o1-mini", "capabilities": ["chat", "reasoning"]},
      {"id": "o3-mini", "capabilities": ["chat", "tools", "reasoning"]},
      {"id": "gpt-4-turbo", "capabilities": ["chat", "tools", "vision"]},
      {"id": "gpt-image-1", "capabilities": ["image"]}
    ],
    "docs_url": "https://platform.openai.com/docs"
  },
  {
    "id": "anthropic",
