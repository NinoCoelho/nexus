        "id": "iam_gcp",
        "label": "Service account",
        "priority": 100,
        "requires_extra": "vertex",
        "prompts": [
          {
            "name": "iam_profile",
            "label": "Service-account JSON path",
            "kind": "text",
            "placeholder": "/Users/me/keys/vertex-sa.json",
            "help": "Absolute path to a downloaded service-account JSON file. Leave empty to use Application Default Credentials.",
            "required": false
          },
          {
            "name": "iam_extra.project",
            "label": "GCP project ID",
            "kind": "text",
            "required": true
          },
          {
            "name": "iam_region",
            "label": "Region",
            "kind": "text",
            "default": "us-central1",
            "required": true
          }
        ]
      }
